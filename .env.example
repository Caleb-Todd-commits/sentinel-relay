# Sentinel Relay shared environment example
# Copy this file to .env and fill local values. Never commit real secrets.

NEXT_PUBLIC_APP_NAME="Sentinel Relay"

# Frontend collaboration mode. Use "mock" for demo stability; switch to "band"
# only after the server-side Band values below are configured.
NEXT_PUBLIC_COLLABORATION_MODE="mock"
NEXT_PUBLIC_ENABLE_BAND_MODE="false"
NEXT_PUBLIC_COLLABORATION_API_BASE_PATH="/api/collaboration"

# Server-side Band adapter. These must never be NEXT_PUBLIC.
BAND_PROVIDER_ENABLED="false"
BAND_DRY_RUN="false"
BAND_API_BASE_URL="https://app.band.ai/api/v1"
BAND_WS_URL="wss://app.band.ai/api/v1/socket/websocket"

# Band Leader creates rooms, adds participants, posts structured events, and
# routes @mentioned messages.
BAND_LEADER_AGENT_API_KEY=""
BAND_LEADER_AGENT_ID=""
BAND_LEADER_HANDLE=""
BAND_LEADER_NAME="Band Leader"

# Optional. Without this, Sentinel Relay uses the local server mirror for
# judge-facing room history.
BAND_HUMAN_API_KEY=""

# Specialist external remote agents.
FORENSICS_AGENT_ID=""
FORENSICS_AGENT_API_KEY=""
FORENSICS_AGENT_HANDLE=""

THREAT_INTEL_AGENT_ID=""
THREAT_INTEL_AGENT_API_KEY=""
THREAT_INTEL_AGENT_HANDLE=""

CODE_REVIEW_AGENT_ID=""
CODE_REVIEW_AGENT_API_KEY=""
CODE_REVIEW_AGENT_HANDLE=""

RISK_COMPLIANCE_AGENT_ID=""
RISK_COMPLIANCE_AGENT_API_KEY=""
RISK_COMPLIANCE_AGENT_HANDLE=""

REMEDIATION_AGENT_ID=""
REMEDIATION_AGENT_API_KEY=""
REMEDIATION_AGENT_HANDLE=""

# Model/provider keys.
OPENAI_API_KEY=""
AIMLAPI_API_KEY=""
AIMLAPI_BASE_URL="https://api.aimlapi.com/v1"
AIMLAPI_MODEL="gpt-4o-mini"
FEATHERLESS_API_KEY=""
