{
  "name": "sentinel-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Sentinel Relay: a Band-powered multi-agent cybersecurity incident command center.",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "corepack pnpm --filter sentinel-relay-web dev",
    "build": "corepack pnpm --filter sentinel-relay-web build",
    "start": "corepack pnpm --filter sentinel-relay-web start",
    "lint": "corepack pnpm --filter sentinel-relay-web lint",
    "typecheck": "corepack pnpm --filter sentinel-relay-web typecheck",
    "verify": "bash scripts/dev/verify-web-baseline.sh && python scripts/workflow/verify-mock-flow.py && python scripts/provider/verify-provider-layer.py && python scripts/report/verify-report-layer.py && python scripts/demo/verify-evidence-pack.py && python3 agents/mock/run_mock_flow.py",
    "web:dev": "corepack pnpm --filter sentinel-relay-web dev",
    "web:build": "corepack pnpm --filter sentinel-relay-web build",
    "web:start": "corepack pnpm --filter sentinel-relay-web start",
    "web:lint": "corepack pnpm --filter sentinel-relay-web lint",
    "web:typecheck": "corepack pnpm --filter sentinel-relay-web typecheck",
    "repo:labels": "bash scripts/github/create-labels.sh",
    "repo:milestones": "bash scripts/github/create-milestones.sh",
    "repo:issues": "bash scripts/github/create-first-issues.sh",
    "repo:setup-local": "bash scripts/github/setup-repo-local.sh",
    "schemas:typecheck": "corepack pnpm --filter @sentinel-relay/schemas typecheck",
    "schemas:validate": "python scripts/schema/validate-sample-data.py",
    "schemas:contract": "bash scripts/schema/check-schema-contracts.sh",
    "workflow:verify": "python scripts/workflow/verify-mock-flow.py",
    "workflow:evidence": "python scripts/demo/run-evidence-band-workflow.py",
    "workflow:evidence:live": "python scripts/demo/run-evidence-band-workflow.py --require-aimlapi",
    "workflow:evidence:verify": "python scripts/demo/verify-evidence-pack.py",
    "agents:verify": "python3 agents/mock/run_mock_flow.py",
    "provider:verify": "python scripts/provider/verify-provider-layer.py && python scripts/band/verify-band-integration.py",
    "band:verify": "python scripts/band/verify-band-integration.py",
    "band:env": "python scripts/band/print-band-env-check.py",
    "band:smoke": "python scripts/band/band-smoke-test.py",
    "report:verify": "python scripts/report/verify-report-layer.py"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
