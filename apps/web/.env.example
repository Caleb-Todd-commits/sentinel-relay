# Sentinel Relay shared environment example
# Copy to apps/web/.env.local and/or agents/.env as needed. Never commit real secrets.

NEXT_PUBLIC_APP_NAME="Sentinel Relay"

# Frontend collaboration mode. Keep mock for normal demo stability.
# Switch to band only after the server-side BAND_* values below are configured.
NEXT_PUBLIC_COLLABORATION_MODE="mock"
NEXT_PUBLIC_ENABLE_BAND_MODE="false"
NEXT_PUBLIC_COLLABORATION_API_BASE_PATH="/api/collaboration"

# Server-side Band adapter. These must never be NEXT_PUBLIC.
BAND_PROVIDER_ENABLED="false"
BAND_DRY_RUN="false"
BAND_API_BASE_URL="https://app.band.ai/api/v1"
BAND_WS_URL="wss://app.band.ai/api/v1/socket/websocket"

# Commander agent key is used by Sentinel Relay server routes to create rooms,
# add participants, post structured events, and route @mentioned messages.
BAND_COMMANDER_AGENT_API_KEY=""
BAND_COMMANDER_PARTICIPANT_ID=""
BAND_COMMANDER_HANDLE=""
BAND_COMMANDER_NAME="Incident Commander Agent"

# Optional Human API key allows the server/dashboard to read full room history.
# Without it, Sentinel Relay uses the local server mirror for judge-facing history.
BAND_HUMAN_API_KEY=""
BAND_DASHBOARD_HUMAN_PARTICIPANT_ID=""

# Participant IDs are the Band peer/participant IDs that can be invited/mentioned.
BAND_FORENSICS_PARTICIPANT_ID=""
BAND_FORENSICS_HANDLE=""
BAND_FORENSICS_NAME="Forensics Agent"

BAND_THREAT_INTEL_PARTICIPANT_ID=""
BAND_THREAT_INTEL_HANDLE=""
BAND_THREAT_INTEL_NAME="Threat Intel Agent"

BAND_CODE_REVIEW_PARTICIPANT_ID=""
BAND_CODE_REVIEW_HANDLE=""
BAND_CODE_REVIEW_NAME="Code Review Agent"

BAND_RISK_COMPLIANCE_PARTICIPANT_ID=""
BAND_RISK_COMPLIANCE_HANDLE=""
BAND_RISK_COMPLIANCE_NAME="Risk & Compliance Agent"

BAND_REMEDIATION_PARTICIPANT_ID=""
BAND_REMEDIATION_HANDLE=""
BAND_REMEDIATION_NAME="Remediation Agent"

# Per-agent worker values. These are used by agents/* runners, not the browser.
COMMANDER_AGENT_ID=""
COMMANDER_AGENT_API_KEY=""
FORENSICS_AGENT_ID=""
FORENSICS_AGENT_API_KEY=""
THREAT_INTEL_AGENT_ID=""
THREAT_INTEL_AGENT_API_KEY=""
CODE_REVIEW_AGENT_ID=""
CODE_REVIEW_AGENT_API_KEY=""
RISK_COMPLIANCE_AGENT_ID=""
RISK_COMPLIANCE_AGENT_API_KEY=""
REMEDIATION_AGENT_ID=""
REMEDIATION_AGENT_API_KEY=""

OPENAI_API_KEY=""
AIMLAPI_API_KEY=""
FEATHERLESS_API_KEY=""
